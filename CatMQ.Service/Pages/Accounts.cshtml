@page
@using NTDLS.Helpers
@model AccountsModel
@{
    ViewData["Title"] = "Accounts";
}

<div>
    <div class="d-flex justify-content-between align-items-center mx-0 my-0">
        <div>
            @* Left-aligned "toolbar" controls *@
            <h5 class="display-6">
                Accounts
            </h5>
        </div>

        <div>
             @* Right-aligned "toolbar" controls  *@
            <a href="/CreateAccount" class="btn btn-primary">Create Account</a>
        </div>
    </div>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <p class="fw-bold">@Html.Raw(Model.ErrorMessage)</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post">
        <div class="table-responsive shadow-lg">
            <table class="table table-striped table-bordered mx-0 my-0">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Description</th>
                        <th>Time-zone</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in Model.Accounts)
                    {
                        <tr>
                            <td><a href="/Account/@account.Id">@account.Username</a></td>
                            <td>@account.Description</td>
                            <td>@account.TimeZone</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </form>
</div>

