@page "/message/{QueueName}/{SerialNumber:long}"
@model MessageModel
@{
    ViewData["Title"] = $"{@Model.QueueName} Queue";
}

<style>
    .message-body {
        font-size: 1rem;
        margin-bottom: 1rem;
        white-space: pre-wrap;
        word-break: break-word;
        overflow-wrap: anywhere;
    }
</style>

<div>
    <h5 class="display-6">
        @Model.QueueName
        <a href="/Messages/@Model.QueueName" class="btn btn-outline-secondary" title="Back to messages">
            <i class="bi bi-arrow-up"></i>
        </a>
    </h5>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <p class="fw-bold">@Html.Raw(Model.ErrorMessage)</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Message != null)
    {
        <div class="table-responsive shadow-lg">
            <table class="table table-striped table-bordered mx-0 my-0">
                <thead>
                    <tr>
                        <th colspan="8">Metadata</th>
                    </tr>
                </thead>
                <thead>
                    <tr>
                        <th>
                            Serial
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="The queue-scoped unique identifier for this message. Note that if the message is moved from one queue to another, such as in dead-lettering, that the message will receive a new id."></i>
                        </th>
                        <th>
                            Timestamp
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="UTC date and time when the message was enqueued."></i>
                        </th>
                        <th>
                            Due
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="For deferred messages, the due time defines when the message is next scheduled for delivery."></i>
                        </th>
                        <th class="text-end">
                            Deferred
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="The cumulative number of times that this message has been delivered to a subscriber where that subscriber requested that the message be redelivered at a later time."></i>
                        </th>
                        <th class="text-end">
                            Subscribers
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="Current number of subscribers that are subscribed to this message."></i>
                        </th>
                        <th class="text-end">
                            Delivered
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="The cumulative number of times that this message has been delivered to a subscriber."></i>
                        </th>
                        <th class="text-end">
                            Consumed
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="The cumulative number of times that this message has been delivered to a subscriber where the subscriber responded with a consumption disposition."></i>
                        </th>
                        <th>
                            Type
                            <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                               title="Native type of the serialized object in the queue."></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.Message.SerialNumber</td>
                        <td>@Model.Message.Timestamp</td>
                        <td>@(Model.Message.DeferredUntil?.ToString() ?? "asap")</td>
                        <td>@Model.Message.DeferredDeliveryCount.ToString("n0")</td>
                        <td>@Model.Message.SubscriberCount.ToString("n0")</td>
                        <td>@Model.Message.SubscriberMessageDeliveries.Count.ToString("n0")</td>
                        <td>@Model.Message.SatisfiedSubscribersSubscriberIDs.Count.ToString("n0")</td>
                        <td>@Model.Message.AssemblyQualifiedTypeName</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="table-responsive shadow-lg mt-2">
            <table class="table table-striped table-bordered mx-0 my-0">
                <thead>
                    <tr>
                        <th>Message Body</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="message-body">
                            <pre class="message-body">@Model.Message.MessageJson</pre>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>
