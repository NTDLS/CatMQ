@page
@using NTDLS.Helpers
@model QueuesModel
@{
    ViewData["Title"] = "Queues";
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            await refreshQueues();
            setInterval(refreshQueues, 5000);
        });

        async function refreshQueues() {
            try {
                const url = `?handler=Queues`;
                const response = await fetch(url, {
                    headers: { 'Accept': 'application/json' }
                });

                if (!response.ok) {
                    console.error('Failed to load queues. HTTP', response.status);
                    return;
                }

                const data = await response.json();
                renderQueues(data);
            } catch (err) {
                console.error('Error loading queues:', err);
            }
        }

        function buildRow(queue) {
            return `
                <tr${queue.errorMessage ? ' class="table-danger"' : ''}>
                    <td><a href="/queue/${queue.queueName}">${queue.queueName}</a></td>
                    <td class="text-end">${queue.currentSubscriberCount}</td>
                    <td class="text-end"><a href="/messages/${queue.queueName}">${queue.queueDepth}</a></td>
                    <td class="text-end">${queue.currentOutstandingDeliveries}</td>
                    <td class="text-end">${queue.receivedMessageCount}</td>
                    <td class="text-end">${queue.deliveredMessageCount}</td>
                    <td class="text-end">${queue.deferredDeliveryCount}</td>
                    <td class="text-end">${queue.expiredMessageCount}</td>
                    <td class="text-end">${queue.failedDeliveryCount}</td>
                </tr>`;
        }

        function renderQueues(queues) {
            const tbody = document.getElementById('queues-body');
            if (!tbody) return;

            if (!Array.isArray(queues) || queues.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            No queues.
                        </td>
                    </tr>`;
                return;
            }

            const rowsHtml = queues.map(buildRow).join('');
            tbody.innerHTML = rowsHtml;
        }

    </script>
}

<div>
    <h5 class="display-6">
        Queues
        <a href="/" class="btn btn-outline-secondary" title="Back to home">
            <i class="bi bi-arrow-up"></i>
        </a>
    </h5>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <p class="fw-bold">@Html.Raw(Model.ErrorMessage)</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive shadow-lg">
        <table class="table table-striped table-bordered mx-0 my-0">
            <thead>
                <tr>
                    <th class="text-start">
                        Name
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Name of the queue."></i>
                    </th>
                    <th class="text-end">
                        Subscribers
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Current number of subscribers to the queue."></i>
                    </th>
                    <th class="text-end">
                        Depth
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Current number of messages in the queue."></i>
                    </th>
                    <th class="text-end">
                        Outstanding
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Current number of messages that are out-for-delivery. These messages have been dispatched and are awaiting a disposition from a subscriber."></i>
                    </th>
                    <th class="text-end">
                        Received
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Cumulative number of messages that have been received into the queue."></i>
                    </th>
                    <th class="text-end">
                        Delivered
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Cumulative number of messages that have been delivered to subscribers from the queue."></i>
                    </th>
                    <th class="text-end">
                        Deferred
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Cumulative number of messages that have been delivered to subscribers where the subscriber requested that the message be redelivered at a later time."></i>
                    </th>
                    <th class="text-end">
                        Expired
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Cumulative number of messages that have expired while waiting to be delivered. Depending on the configuration, these messages are either discarded or moved to the dead-letter-queue."></i>
                    </th>
                    <th class="text-end">
                        Delivery Failures
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Cumulative number of messages where delivery attempts resulted in an exception."></i>
                    </th>
                </tr>
            </thead>

            <tbody id="queues-body">
                <!-- Filled by JS -->
            </tbody>
        </table>
    </div>
</div>
