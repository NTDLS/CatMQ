@page
@using NTDLS.Helpers
@model ConfigurationModel
@{
    ViewData["Title"] = "Configuration";
}

<div>
    <form method="post">
    <div class="d-flex justify-content-between align-items-center mx-0 my-0">
        <div>
            @* Left-aligned "toolbar" controls *@
            <h5 class="display-6">
                Configuration
            </h5>
        </div>

        <div>
            @* Right-aligned "toolbar" controls  *@
                <button type="submit" class="btn btn-primary mt-2">Save</button>
        </div>
    </div>


    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <p class="fw-bold">@Html.Raw(Model.ErrorMessage)</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.SuccessMessage != null)
    {
        <div id="success-alert" class="alert alert-success alert-dismissible fade show" role="alert">
            <p class="fw-bold">@Html.Raw(Model.SuccessMessage)</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>

        <script>
                document.addEventListener("DOMContentLoaded", function () {
                    setTimeout(function () {
                        let alertElement = document.getElementById('success-alert');
                        if (alertElement) {
                            // Add fade-out effect
                            alertElement.classList.remove('show');
                            alertElement.classList.add('fade');

                            // Remove the alert completely after the fade-out animation
                            setTimeout(() => alertElement.remove(), 300);
                        }
                    }, 5000);
                });
        </script>
    }
        <div class="card shadow-lg">
            <div class="card-header">
                <h5>Web Administration</h5>
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label for="EnableWebUI" class="form-label fw-bold">Enabled Web UI</label>
                    <span asp-validation-for="ServerConfig.EnableWebUI" class="text-danger"></span>
                    <select id="enableWebUI" asp-for="ServerConfig.EnableWebUI" class="form-select">
                        <option value="true">True</option>
                        <option value="false">False</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="webUIURL" class="form-label fw-bold">Web UI Binding</label>
                    <span asp-validation-for="ServerConfig.WebListenURL" class="text-danger"></span>
                    <input type="text" id="webUIURL" class="form-control" asp-for="ServerConfig.WebListenURL">
                </div>

                <div class="mb-3">
                    <label for="dataPath" class="form-label fw-bold">Data Path</label>
                    <span asp-validation-for="ServerConfig.DataPath" class="text-danger"></span>
                    <input type="text" id="dataPath" class="form-control" placeholder="Enter file path" asp-for="ServerConfig.DataPath">
                </div>
            </div>
        </div>

        <div class="card shadow-lg mt-2">
            <div class="card-header">
                <h5>Message Queue</h5>
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label for="queuePort" class="form-label fw-bold">Queue Port</label>
                    <span asp-validation-for="ServerConfig.QueuePort" class="text-danger"></span>
                    <input type="number" id="queuePort" class="form-control" asp-for="ServerConfig.QueuePort" min="1" max="65535">
                </div>
                <div class="mb-3">
                    <label for="dataPath" class="form-label fw-bold">Data Path</label>
                    <span asp-validation-for="ServerConfig.DataPath" class="text-danger"></span>
                    <input type="text" id="dataPath" class="form-control" placeholder="Enter file path" asp-for="ServerConfig.DataPath">
                </div>
                <div class="mb-3">
                    <label for="EnableWebUI" class="form-label fw-bold">Enable Instrumentation</label>
                    <span asp-validation-for="ServerConfig.EnableInstrumentation" class="text-danger"></span>
                    <select id="enableInstrumentation" asp-for="ServerConfig.EnableInstrumentation" class="form-select">
                        <option value="true">True</option>
                        <option value="false">False</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="card shadow-lg mt-2">
            <div class="card-header">
                <h5>Messaging</h5>
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label for="acknowledgmentTimeoutSeconds" class="form-label fw-bold">Query Timeout (s)</label>
                    <span asp-validation-for="ServerConfig.AcknowledgmentTimeoutSeconds" class="text-danger"></span>
                    <input type="number" id="acknowledgmentTimeoutSeconds" class="form-control" asp-for="ServerConfig.AcknowledgmentTimeoutSeconds" min="1">
                </div>
                <div class="mb-3">
                    <label for="initialReceiveBufferSize" class="form-label fw-bold">Initial Receive Buffer Size (bytes)</label>
                    <span asp-validation-for="ServerConfig.InitialReceiveBufferSize" class="text-danger"></span>
                    <input type="number" id="initialReceiveBufferSize" class="form-control" asp-for="ServerConfig.InitialReceiveBufferSize" min="1024">
                </div>
                <div class="mb-3">
                    <label for="maxReceiveBufferSize" class="form-label fw-bold">Max Receive Buffer Size (bytes)</label>
                    <span asp-validation-for="ServerConfig.MaxReceiveBufferSize" class="text-danger"></span>
                    <input type="number" id="maxReceiveBufferSize" class="form-control" asp-for="ServerConfig.MaxReceiveBufferSize" min="1024">
                </div>
                <div class="mb-3">
                    <label for="receiveBufferGrowthRate" class="form-label fw-bold">Receive Buffer Growth Rate (decimal %)</label>
                    <span asp-validation-for="ServerConfig.ReceiveBufferGrowthRate" class="text-danger"></span>
                    <input type="number" id="receiveBufferGrowthRate" class="form-control" asp-for="ServerConfig.ReceiveBufferGrowthRate" step="0.1" min="0.1">
                </div>

            </div>
        </div>
    </form>
</div>
