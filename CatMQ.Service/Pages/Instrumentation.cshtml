@page
@using NTDLS.Helpers
@model InstrumentationModel
@{
    ViewData["Title"] = "Instrumentation";
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            await refreshInstrumentation();
            setInterval(refreshInstrumentation, 5000);
        });

        async function refreshInstrumentation() {
            try {
                const url = `?handler=Instrumentation`;
                const response = await fetch(url, {
                    headers: { 'Accept': 'application/json' }
                });

                if (!response.ok) {
                    console.error('Failed to load instrumentation. HTTP', response.status);
                    return;
                }

                const data = await response.json();      


                console.log(data);

                renderInstrumentation(data);
            } catch (err) {
                console.error('Error loading instrumentation:', err);
            }
        }

        function buildRow(item) {
            return `
                <tr>
                    <td>${item.key}</td>
                    <td class="text-end">
                        ${(item.value.count ?? 0).toLocaleString(undefined, {
                            minimumFractionDigits: 0,
                            maximumFractionDigits: 0
                        })}
                    </td>
                    <td class="text-end">
                        ${(item.value.milliseconds ?? 0).toLocaleString(undefined, {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        })}
                    </td>
                </tr>`;
        }

        function renderInstrumentation(instrumentation) {
            const tbody = document.getElementById('instrumentation-body');
            if (!tbody) return;

            if (!Array.isArray(instrumentation) || instrumentation.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="3" class="text-center text-muted">
                            No instrumentation data.
                        </td>
                    </tr>`;
                return;
            }

            const rowsHtml = instrumentation.map(buildRow).join('');
            tbody.innerHTML = rowsHtml;
        }

    </script>
}

<div>
    <h5 class="display-6">
        Instrumentation
    </h5>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <p class="fw-bold">@Html.Raw(Model.ErrorMessage)</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive shadow-lg">
        <table class="table table-striped table-bordered mx-0 my-0">
            <thead>
                <tr>
                    <th class="text-start">Metric</th>
                    <th class="text-end">Event Count</th>
                    <th class="text-end">Event Time (ms)</th>
                </tr>
            </thead>

            <tbody id="instrumentation-body">
                <!-- Filled by JS -->
            </tbody>
        </table>
    </div>
</div>
