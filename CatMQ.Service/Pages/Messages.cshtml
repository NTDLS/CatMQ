@page "/messages/{QueueName}/{PageNumber:int=0}"
@model MessagesModel
@{
    ViewData["Title"] = $"{@Model.QueueName} Queue";
}

<div>
    <div class="d-flex justify-content-between align-items-center mx-0 my-0">
        <div>
            @* Left-aligned "toolbar" controls *@
            <h5 class="display-6">
                @Model.QueueName Messages
            </h5>
        </div>

        <div>
            @* Right-aligned "toolbar" controls  *@
            <a href="/queue/@Model.QueueName" class="btn btn-outline-secondary" title="Back to queue">
                <i class="bi bi-arrow-up"></i>
            </a>
        </div>
    </div>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <p class="fw-bold">@Html.Raw(Model.ErrorMessage)</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="my-2">
        <div class="d-flex justify-content-center">
            <div class="btn-group" role="group">
                <a class="btn btn-outline-secondary @(Model.PageNumber <= 0 ? "disabled" : "")" href="/messages/@Model.QueueName/0">
                    <i class="bi bi-chevron-double-left"></i>
                </a>
                <a class="btn btn-outline-secondary @(Model.PageNumber <= 0 ? "disabled" : "")" href="/messages/@Model.QueueName/@(Model.PageNumber - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
                <a class="btn btn-outline-secondary @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")" href="/messages/@Model.QueueName/@(Model.PageNumber + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
                <a class="btn btn-outline-secondary @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")" href="/messages/@Model.QueueName/@(Model.TotalPages)">
                    <i class="bi bi-chevron-double-right"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="table-responsive shadow-lg">
        <table class="table table-striped table-bordered mx-0 my-0">
            <thead>
                <tr>
                    <th>Serial
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="The queue-scoped unique identifier for this message. Note that if the message is moved from one queue to another, such as in dead-lettering, that the message will receive a new id."></i>
                    </th>
                    <th>Timestamp
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="UTC date and time when the message was enqueued."></i>
                    </th>
                    <th>Due
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="For deferred messages, the due time defines when the message is next scheduled for delivery."></i>
                    </th>
                    <th class="text-end">Deferred
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="The cumulative number of times that this message has been delivered to a subscriber where that subscriber requested that the message be redelivered at a later time."></i>
                    </th>
                    <th class="text-end">Subscribers
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Current number of subscribers that are subscribed to this message."></i>
                    </th>
                    <th class="text-end">Delivered
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="The cumulative number of times that this message has been delivered to a subscriber."></i>
                    </th>
                    <th class="text-end">Consumed
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="The cumulative number of times that this message has been delivered to a subscriber where the subscriber responded with a consumption disposition."></i>
                    </th>
                    <th>Type
                        <i class="bi bi-info-circle ms-1 text-muted" data-bs-toggle="tooltip" data-bs-placement="top"
                           title="Native type of the serialized object in the queue."></i>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var message in Model.Messages)
                {
                    <tr>
                        <td><a href="/message/@Model.QueueName/@message.SerialNumber">@message.SerialNumber</a></td>
                        <td>@message.Timestamp</td>
                        <td>@(message.DeferredUntil?.ToString() ?? "asap")</td>
                        <td class="text-end">@message.DeferredDeliveryCount.ToString("n0")</td>
                        <td class="text-end">@message.SubscriberCount.ToString("n0")</td>
                        <td class="text-end">@message.SubscriberMessageDeliveries.Count.ToString("n0")</td>
                        <td class="text-end">@message.SatisfiedSubscribersSubscriberIDs.Count.ToString("n0")</td>
                        <td>@message.AssemblyQualifiedTypeName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-2">
        <div class="d-flex justify-content-center">
            <div class="btn-group" role="group">
                <a class="btn btn-outline-secondary @(Model.PageNumber <= 0 ? "disabled" : "")" href="/messages/@Model.QueueName/0">
                    <i class="bi bi-chevron-double-left"></i>
                </a>
                <a class="btn btn-outline-secondary @(Model.PageNumber <= 0 ? "disabled" : "")" href="/messages/@Model.QueueName/@(Model.PageNumber - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
                <a class="btn btn-outline-secondary @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")" href="/messages/@Model.QueueName/@(Model.PageNumber + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
                <a class="btn btn-outline-secondary @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")" href="/messages/@Model.QueueName/@(Model.TotalPages)">
                    <i class="bi bi-chevron-double-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

